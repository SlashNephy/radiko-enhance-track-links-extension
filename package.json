{
  "name": "radiko-enhance-track-links-extension",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "compile": "tsc --noEmit",
