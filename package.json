    "zip:firefox": "wxt zip -b firefox"
  },
  "dependencies": {
    "jaconv": "1.1.2",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@slashnephy/eslint-config": "3.0.357",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@wxt-dev/module-react": "1.2.2",
    "eslint": "9.39.4",
    "typescript": "6.0.3",
    "wxt": "0.20.26"
  },
  "packageManager": "pnpm@11.5.3"
}
